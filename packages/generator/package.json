{
  "name": "@nexcms/generator",
  "version": "0.0.0",
  "description": "Core generator — project.json → Astro output files",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@nexcms/types": "workspace:*",
    "@nexcms/template-engine": "workspace:*",
    "@nexcms/asset-tools": "workspace:*",
    "@nexcms/seo-tools": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  }
}
