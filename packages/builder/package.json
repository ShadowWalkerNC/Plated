{
  "name": "@plated/builder",
  "version": "0.2.0",
  "private": true,
  "main": "./dist/electron/main.js",
  "scripts": {
    "dev":        "concurrently -n vite,electron \"vite\" \"wait-on tcp:5180 && electron .\"",
    "build":      "vite build && tsc -p tsconfig.electron.json",
    "dist:mac":   "npm run build && electron-builder --mac",
    "dist:win":   "npm run build && electron-builder --win",
    "dist:linux": "npm run build && electron-builder --linux",
    "dist:all":   "npm run build && electron-builder --mac --win --linux",
    "typecheck":  "tsc --noEmit && tsc --noEmit -p tsconfig.electron.json",
    "test":       "vitest run"
  },
  "build": {
    "appId":       "io.plated.builder",
    "productName": "Plated Builder",
    "copyright":   "Copyright © 2026 Plated",
    "directories": { "output": "release" },
    "files":       ["dist/**", "dist-electron/**", "splash.html"],
    "extraResources": [
      {
        "from": "../../styles",
        "to": "styles",
        "filter": ["**/*"]
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner":    "ShadowWalkerNC",
        "repo":     "NexCMS"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon":     "assets/icon.icns",
      "target":   [{ "target": "dmg", "arch": ["x64", "arm64"] }],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements":        "assets/entitlements.mac.plist",
      "entitlementsInherit": "assets/entitlements.mac.plist"
    },
    "win": {
      "icon":          "assets/icon.ico",
      "target":        [{ "target": "nsis", "arch": ["x64"] }],
      "publisherName": "Plated"
    },
    "linux": {
      "icon":     "assets/icon.png",
      "target":   [{ "target": "AppImage", "arch": ["x64"] }],
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@plated/astro-output": "workspace:*",
    "@plated/generator":   "workspace:*",
    "@plated/types":       "workspace:*",
    "@plated/pdf-tools":   "workspace:*",
    "@imgly/background-removal": "^1.4.0",
    "react-image-crop":    "^11.0.5",
    "@dnd-kit/core":       "^6.1.0",
    "@dnd-kit/sortable":   "^8.0.0",
    "@dnd-kit/utilities":  "^3.2.2",
    "zustand":             "^4.5.2",
    "electron-updater":    "^6.3.0",
    "react":               "^18.3.0",
    "react-dom":           "^18.3.0"
  },
  "devDependencies": {
    "@types/react":         "^18.3.0",
    "@types/react-dom":     "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently":         "^9.0.0",
    "electron":             "^33.0.0",
    "electron-builder":     "^25.0.0",
    "typescript":           "^5.7.0",
    "vite":                 "^6.0.0",
    "vitest":               "^2.0.0",
    "wait-on":              "^8.0.0"
  }
}
