{
  "name": "@nexcms/template-engine",
  "version": "0.0.0",
  "description": "Template engine — reads nexcms.template.json manifests and maps content slots",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@nexcms/types": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  }
}
