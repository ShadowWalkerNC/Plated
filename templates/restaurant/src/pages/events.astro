---
import Base from '../../layouts/Base.astro';
const { site } = Astro.locals;
const upcomingEvents = (site.events ?? []).filter((e) => !e.isPast);
const pastEvents = (site.events ?? []).filter((e) => e.isPast);
---
<Base title={`Events — ${site.business.name}`} description={`Upcoming events at ${site.business.name}.`}>

  <section class="section events-header">
    <div class="container text-center">
      <h1 class="page-title">Events</h1>
    </div>
  </section>

  {upcomingEvents.length > 0 ? (
    <section class="section events-list-section">
      <div class="container">
        <h2 class="section-heading">Upcoming</h2>
        <ul class="events-list">
          {upcomingEvents.map((event) => (
            <li class="event-card">
              {event.imageUrl && (
                <div class="event-image-wrap">
                  <img src={event.imageUrl} alt={event.title} class="event-image" loading="lazy" />
                </div>
              )}
              <div class="event-details">
                <h3 class="event-title">{event.title}</h3>
                <p class="event-datetime">
                  {event.date}{event.time ? ` · ${event.time}` : ''}
                </p>
                {event.description && <p class="event-description">{event.description}</p>}
                {event.ticketUrl && (
                  <a class="btn btn-primary" href={event.ticketUrl} target="_blank" rel="noreferrer">Tickets</a>
                )}
              </div>
            </li>
          ))}
        </ul>
      </div>
    </section>
  ) : (
    <section class="section">
      <div class="container text-center">
        <p>No upcoming events. Check back soon.</p>
      </div>
    </section>
  )}

  {pastEvents.length > 0 && (
    <section class="section past-events-section">
      <div class="container">
        <h2 class="section-heading past-heading">Past Events</h2>
        <ul class="events-list events-list--past">
          {pastEvents.map((event) => (
            <li class="event-card event-card--past">
              <div class="event-details">
                <h3 class="event-title">{event.title}</h3>
                <p class="event-datetime">{event.date}</p>
                {event.description && <p class="event-description">{event.description}</p>}
              </div>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

</Base>
