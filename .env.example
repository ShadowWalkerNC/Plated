# NexCMS — Environment Variables
# Copy this file to .env and fill in values.
# Never commit actual values.

# ── Core (Both Modes) ──────────────────────────────────────

NODE_ENV=development

# ── SaaS Only ──────────────────────────────────────────────

# Supabase project URL (safe to expose — no secrets)
PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon key (client-safe, exposed to browser)
PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key — SERVER-SIDE ONLY
# NEVER prefix with PUBLIC_. NEVER expose to client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Cloudflare Zone ID (for cache purge on content save)
CLOUDFLARE_ZONE_ID=your-zone-id-here

# Cloudflare API Token (cache purge permissions only)
CLOUDFLARE_API_TOKEN=your-cloudflare-token-here

# Resend API key (form submission email notifications)
RESEND_API_KEY=re_your-resend-key-here

# SaaS server port (defaults to 3000)
# PORT=3000

# ── Local Builder Only ─────────────────────────────────────

# Encryption key for storing OAuth tokens locally (32-byte hex)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-32-byte-hex-encryption-key-here

# ── Square Integration ─────────────────────────────────────
# https://developer.squareup.com/apps

# Square OAuth app ID (safe to expose in Local Builder)
SQUARE_APP_ID=your-square-app-id-here

# Square OAuth app secret — SERVER-SIDE ONLY (SaaS)
SQUARE_APP_SECRET=your-square-app-secret-here

# Square environment: sandbox or production
SQUARE_ENVIRONMENT=sandbox

# ── Meta Integration (Facebook + Instagram) ────────────────
# https://developers.facebook.com/apps

# Meta app ID (safe to expose)
META_APP_ID=your-meta-app-id-here

# Meta app secret — SERVER-SIDE ONLY (SaaS)
META_APP_SECRET=your-meta-app-secret-here

# ── Twitter / X Integration ────────────────────────────────
# https://developer.twitter.com/en/portal/dashboard

# X OAuth 2.0 client ID (safe to expose)
TWITTER_CLIENT_ID=your-twitter-client-id-here

# X OAuth 2.0 client secret — SERVER-SIDE ONLY (SaaS)
TWITTER_CLIENT_SECRET=your-twitter-client-secret-here

# ── Google Integration ─────────────────────────────────────
# https://console.cloud.google.com/apis/credentials
# Enable: Google Business Profile API, Maps Embed API, Maps JavaScript API

# Google OAuth 2.0 client ID (safe to expose)
GOOGLE_CLIENT_ID=your-google-client-id-here

# Google OAuth 2.0 client secret — SERVER-SIDE ONLY (SaaS)
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# Google Maps API key (safe to expose — restrict to your domain in GCP console)
PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# ── Apple Maps Integration ─────────────────────────────────
# https://developer.apple.com/maps/

# Apple Maps JS token (safe to expose)
APPLE_MAPS_TOKEN=your-apple-maps-token-here

# Apple Maps Business Connect team ID — SERVER-SIDE ONLY (SaaS)
APPLE_MAPS_TEAM_ID=your-apple-team-id-here
