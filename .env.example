# NexCMS — Environment Variables
# Copy this file to .env and fill in real values.
# Never commit actual secrets.
# Last updated: v4.0 — July 4, 2026

# ── Core ───────────────────────────────────────────────────────────────────

NODE_ENV=development

# ── SaaS Only ──────────────────────────────────────────────────────────────

# Supabase project URL (safe to expose)
PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon key (client-safe, exposed to browser)
PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key — SERVER-SIDE ONLY. NEVER prefix with PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Cloudflare Zone ID (for cache purge on content save)
CLOUDFLARE_ZONE_ID=your-zone-id-here

# Cloudflare API Token (cache purge scope only)
CLOUDFLARE_API_TOKEN=your-cloudflare-token-here

# Resend API key (form notification emails)
RESEND_API_KEY=re_your-resend-key-here

# SaaS server port (default: 3000)
# PORT=3000

# ── Local Builder Only ─────────────────────────────────────────────────────

# Encryption key for storing OAuth tokens locally (32-byte hex)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-32-byte-hex-key-here

# ── AI Tools (Gemini) ──────────────────────────────────────────────────────
# https://aistudio.google.com/app/apikey
# SaaS: server-side only. Local: user provides their own key in app settings.

GEMINI_API_KEY=your-gemini-api-key-here

# ── Square ─────────────────────────────────────────────────────────────────
# https://developer.squareup.com/apps
# Covers: Catalog, Orders, Gift Cards, Loyalty APIs

# Square OAuth app ID (safe to expose in Local Builder UI)
SQUARE_APP_ID=your-square-app-id-here

# Square OAuth app secret — SERVER-SIDE ONLY
SQUARE_APP_SECRET=your-square-app-secret-here

# sandbox or production
SQUARE_ENVIRONMENT=sandbox

# ── Meta (Facebook + Instagram) ────────────────────────────────────────────
# https://developers.facebook.com/apps

META_APP_ID=your-meta-app-id-here

# META app secret — SERVER-SIDE ONLY
META_APP_SECRET=your-meta-app-secret-here

# ── Twitter / X ────────────────────────────────────────────────────────────
# https://developer.twitter.com/en/portal/dashboard

TWITTER_CLIENT_ID=your-twitter-client-id-here

# Twitter client secret — SERVER-SIDE ONLY
TWITTER_CLIENT_SECRET=your-twitter-client-secret-here

# ── Google ─────────────────────────────────────────────────────────────────
# https://console.cloud.google.com/apis/credentials
# Enable: Google Business Profile API, Maps Embed API, Maps JavaScript API, Places API

GOOGLE_CLIENT_ID=your-google-client-id-here

# Google client secret — SERVER-SIDE ONLY
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# Maps API key — safe to expose, restrict to your domain in GCP console
PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# ── Apple Maps ─────────────────────────────────────────────────────────────
# https://developer.apple.com/maps/

# Apple Maps JS token (safe to expose)
APPLE_MAPS_TOKEN=your-apple-maps-token-here

# Apple Maps Business Connect team ID — SERVER-SIDE ONLY
APPLE_MAPS_TEAM_ID=your-apple-team-id-here

# ── Yelp ───────────────────────────────────────────────────────────────────
# https://www.yelp.com/developers/documentation/v3/authentication

YELP_API_KEY=your-yelp-api-key-here

# ── Analytics (Plausible) ──────────────────────────────────────────────────
# https://plausible.io/docs/integration-guides
# Default analytics provider — privacy-first, no cookies.

PLAUSIBLE_API_KEY=your-plausible-api-key-here
PLAUSIBLE_DOMAIN=yourdomain.com

# ── Media (Unsplash) ───────────────────────────────────────────────────────
# https://unsplash.com/developers
# Used for stock photo search in the media library.

UNSPLASH_ACCESS_KEY=your-unsplash-access-key-here

# ── SMS / Twilio (Optional) ────────────────────────────────────────────────
# https://console.twilio.com
# Required only if SMS opt-in extension is enabled.

# TWILIO_ACCOUNT_SID=your-twilio-account-sid-here
# TWILIO_AUTH_TOKEN=your-twilio-auth-token-here
# TWILIO_PHONE_NUMBER=+12075551234
